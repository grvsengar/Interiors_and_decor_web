<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Kala Interiors & Decor — Premium interior design and decor services across Telangana. Plywood cupboards, wallpapers, false ceilings, 3D design and more.">
    <title><%= content_for(:title) || "Kala Interiors & Decor" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="turbo-prefetch" content="false">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body class="bg-white antialiased" data-page="<%= action_name == 'home' ? 'home' : 'inner' %>">

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="navbar" style="background: transparent;">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">

          <!-- Logo -->
          <a href="<%= root_path %>" class="flex items-center gap-3 group">
            <div class="w-11 h-11 flex-shrink-0">
              <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="50" cy="50" r="47" stroke="#C9A84C" stroke-width="3"/>
                <rect x="29" y="30" width="42" height="52" rx="21" stroke="#C9A84C" stroke-width="2.5"/>
                <line x1="50" y1="30" x2="50" y2="55" stroke="#C9A84C" stroke-width="2"/>
                <line x1="50" y1="30" x2="29" y2="47" stroke="#C9A84C" stroke-width="2"/>
                <line x1="50" y1="30" x2="71" y2="47" stroke="#C9A84C" stroke-width="2"/>
                <line x1="50" y1="30" x2="35" y2="40" stroke="#C9A84C" stroke-width="1.5"/>
                <line x1="50" y1="30" x2="65" y2="40" stroke="#C9A84C" stroke-width="1.5"/>
                <path d="M29 63 Q40 56 50 60 Q60 64 71 58" stroke="#C9A84C" stroke-width="2" fill="none"/>
                <path d="M29 73 Q40 66 50 70 Q60 74 71 68" stroke="#C9A84C" stroke-width="2" fill="none"/>
              </svg>
            </div>
            <div>
              <div class="text-2xl leading-none text-white group-hover:text-amber-300 transition-colors" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; letter-spacing: 0.05em;">Kala</div>
              <div class="text-xs tracking-widest text-amber-300/80 uppercase" style="font-family: 'Inter', sans-serif; font-size: 9px; letter-spacing: 0.2em;">Interiors & Decor</div>
            </div>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-8">
            <%= link_to "Home", root_path, class: "text-xs tracking-widest uppercase transition-colors hover:text-amber-300 #{current_page?(root_path) ? 'text-amber-300' : 'text-white/80'}", style: "font-family: 'Inter', sans-serif;" %>
            <%= link_to "Services", services_path, class: "text-xs tracking-widest uppercase transition-colors hover:text-amber-300 #{current_page?(services_path) ? 'text-amber-300' : 'text-white/80'}", style: "font-family: 'Inter', sans-serif;" %>
            <%= link_to "Portfolio", portfolio_path, class: "text-xs tracking-widest uppercase transition-colors hover:text-amber-300 #{current_page?(portfolio_path) ? 'text-amber-300' : 'text-white/80'}", style: "font-family: 'Inter', sans-serif;" %>
            <%= link_to "About", about_path, class: "text-xs tracking-widest uppercase transition-colors hover:text-amber-300 #{current_page?(about_path) ? 'text-amber-300' : 'text-white/80'}", style: "font-family: 'Inter', sans-serif;" %>
            <%= link_to "Get A Quote", contact_path, class: "px-5 py-2.5 border border-amber-400/70 text-amber-300 text-xs tracking-widest uppercase hover:bg-amber-400 hover:text-[#0A1628] transition-all duration-200", style: "font-family: 'Inter', sans-serif;" %>
          </div>

          <!-- Mobile menu button -->
          <button class="md:hidden text-white p-2" id="menu-toggle" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div class="hidden md:hidden border-t border-white/10" id="mobile-menu" style="background: rgba(10,22,40,0.98); backdrop-filter: blur(20px);">
        <div class="px-6 py-6 flex flex-col gap-5">
          <%= link_to "Home", root_path, class: "text-white/80 text-xs tracking-widest uppercase hover:text-amber-300" %>
          <%= link_to "Services", services_path, class: "text-white/80 text-xs tracking-widest uppercase hover:text-amber-300" %>
          <%= link_to "Portfolio", portfolio_path, class: "text-white/80 text-xs tracking-widest uppercase hover:text-amber-300" %>
          <%= link_to "About", about_path, class: "text-white/80 text-xs tracking-widest uppercase hover:text-amber-300" %>
          <%= link_to "Get A Quote", contact_path, class: "text-amber-300 text-xs tracking-widest uppercase" %>
        </div>
      </div>
    </nav>

    <!-- Flash messages -->
    <% if notice %>
      <div class="fixed top-24 right-6 z-50 text-white px-6 py-4 text-sm shadow-lg max-w-sm" id="flash-notice" style="background: #1a3a1a; border-left: 3px solid #C9A84C; font-family: 'Inter', sans-serif; font-weight: 300;">
        <%= notice %>
      </div>
    <% end %>
    <% if flash[:error] %>
      <div class="fixed top-24 right-6 z-50 text-white px-6 py-4 text-sm shadow-lg max-w-sm" id="flash-error" style="background: #3a1a1a; border-left: 3px solid #e55; font-family: 'Inter', sans-serif; font-weight: 300;">
        <%= flash[:error] %>
      </div>
    <% end %>

    <!-- Page Content -->
    <main>
      <%= yield %>
    </main>

    <!-- WhatsApp Floating Button -->
