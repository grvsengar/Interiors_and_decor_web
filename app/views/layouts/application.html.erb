        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

          <div>
            <div class="text-4xl font-light mb-1" style="font-family: 'Cormorant Garamond', serif; font-weight: 300; letter-spacing: 0.05em;">Kala</div>
            <div class="text-xs tracking-widest text-amber-400 uppercase mb-6" style="font-family: 'Inter', sans-serif; font-size: 9px; letter-spacing: 0.2em;">Interiors & Decor</div>
            <p class="text-white/40 text-sm leading-relaxed" style="font-family: 'Inter', sans-serif; font-weight: 300;">
              Modern design for your home. Serving all over Telangana with premium interior solutions.
            </p>
            <div class="mt-6 w-12 h-px bg-amber-400/40"></div>
          </div>

          <div>
            <div class="text-xs tracking-widest text-amber-400 uppercase mb-6" style="font-family: 'Inter', sans-serif; font-size: 9px; letter-spacing: 0.2em;">Our Services</div>
            <ul class="space-y-2.5 text-white/50 text-sm" style="font-family: 'Inter', sans-serif; font-weight: 300;">
              <li>Plywood & PVC Cupboards</li>
              <li>False Ceiling & PVC Ceiling</li>
