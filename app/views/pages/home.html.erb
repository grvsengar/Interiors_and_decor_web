          <div class="text-xs mt-1" style="font-family: 'Inter', sans-serif; color: rgba(248,247,244,0.55); font-weight: 300;">Hyderabad, Telangana</div>
        </div>
      </div>

      <div class="group relative overflow-hidden">
        <div style="height: 230px;" class="overflow-hidden">
          <img src="https://images.unsplash.com/photo-1631679706909-1844bbd07221?w=800&q=85&auto=format&fit=crop" alt="Master bedroom design" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
