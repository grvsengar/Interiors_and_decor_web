      </div>

      <div class="group relative overflow-hidden">
        <div style="height: 230px;" class="overflow-hidden">
          <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=85&auto=format&fit=crop" alt="Modern kitchen interior" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
