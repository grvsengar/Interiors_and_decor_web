      <%= link_to portfolio_path, class: "inline-flex items-center gap-3 text-xs tracking-widest uppercase border-b pb-0.5 transition-all hover:gap-5 flex-shrink-0", style: "font-family: 'Inter', sans-serif; color: #C9A84C; border-color: #C9A84C;" do %>
        View Full Portfolio
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      <% end %>
    </div>

    <!-- Masonry-like grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">

      <div class="group relative overflow-hidden col-span-1 md:col-span-2 lg:col-span-1 row-span-2">
        <div style="height: 480px;" class="overflow-hidden">
          <img src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?w=800&q=85&auto=format&fit=crop" alt="Luxury living room Hyderabad" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
