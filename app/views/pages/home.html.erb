<% content_for :title, "Kala Interiors & Decor — Premium Interior Design in Telangana" %>

<!-- HERO SECTION -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden" style="background: #0A1628;">
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?w=1920&q=90&auto=format&fit=crop"
      alt="Luxury interior living room design"
      class="w-full h-full object-cover"
      style="opacity: 0.28;"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,22,40,0.92) 0%, rgba(10,22,40,0.65) 50%, rgba(10,22,40,0.85) 100%);"></div>
  </div>

  <!-- Decorative vertical line -->
  <div class="absolute left-16 top-1/4 bottom-1/4 w-px hidden xl:block" style="background: linear-gradient(to bottom, transparent, rgba(201,168,76,0.4), transparent);"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
    <div class="max-w-3xl">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-12 h-px" style="background: #C9A84C;"></div>
        <span class="text-xs tracking-widest uppercase" style="font-family: 'Inter', sans-serif; color: #C9A84C; letter-spacing: 0.25em;">Premium Interior Design</span>
      </div>

      <h1 class="mb-6 leading-none" style="font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(3rem, 7vw, 6rem); color: #F8F7F4; letter-spacing: -0.01em;">
        Crafting Spaces<br/>
        <em style="color: #C9A84C; font-style: italic;">That Inspire</em><br/>
        Every Day
      </h1>

      <p class="mb-10 max-w-xl leading-relaxed" style="font-family: 'Inter', sans-serif; font-weight: 300; font-size: 1.0625rem; color: rgba(248,247,244,0.65);">
        Kala Interiors & Decor transforms your living spaces into works of art. From custom cupboards to exquisite ceilings, we bring luxury within reach across all of Telangana.
      </p>

      <div class="flex flex-wrap gap-4">
        <%= link_to portfolio_path, class: "inline-flex items-center gap-3 px-8 py-4 text-xs tracking-widest uppercase transition-all duration-300 hover:gap-5", style: "font-family: 'Inter', sans-serif; background: #C9A84C; color: #0A1628; font-weight: 500;" do %>
          Explore Our Work
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
        <%= link_to contact_path, class: "inline-flex items-center gap-3 px-8 py-4 text-xs tracking-widest uppercase transition-all duration-300 hover:bg-white/10", style: "font-family: 'Inter', sans-serif; color: #F8F7F4; border: 1px solid rgba(248,247,244,0.3);" do %>
          Get A Free Quote
        <% end %>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <span class="text-xs tracking-widest uppercase" style="font-family: 'Inter', sans-serif; color: rgba(201,168,76,0.6); font-size: 9px; letter-spacing: 0.2em;">Scroll</span>
    <div class="w-px h-8" style="background: linear-gradient(to bottom, rgba(201,168,76,0.6), transparent);"></div>
  </div>
</section>

<!-- STATS BAR -->
<section style="background: #C9A84C;">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <div class="text-4xl mb-1" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: #0A1628;">500+</div>
        <div class="text-xs tracking-widest uppercase" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.7); font-size: 9px; letter-spacing: 0.18em;">Projects Completed</div>
      </div>
      <div>
        <div class="text-4xl mb-1" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: #0A1628;">8+</div>
        <div class="text-xs tracking-widest uppercase" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.7); font-size: 9px; letter-spacing: 0.18em;">Years Experience</div>
      </div>
      <div>
        <div class="text-4xl mb-1" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: #0A1628;">13</div>
        <div class="text-xs tracking-widest uppercase" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.7); font-size: 9px; letter-spacing: 0.18em;">Services Offered</div>
      </div>
      <div>
        <div class="text-4xl mb-1" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: #0A1628;">100%</div>
        <div class="text-xs tracking-widest uppercase" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.7); font-size: 9px; letter-spacing: 0.18em;">Client Satisfaction</div>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT SECTION -->
<section class="py-24 lg:py-32" style="background: #F8F7F4;">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Images grid -->
      <div class="relative grid grid-cols-2 gap-4">
        <div class="space-y-4">
          <div class="overflow-hidden" style="aspect-ratio: 3/4;">
            <img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=800&q=85&auto=format&fit=crop" alt="Modern living room interior" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"/>
          </div>
          <div class="overflow-hidden" style="aspect-ratio: 4/3;">
            <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=85&auto=format&fit=crop" alt="Luxury kitchen design" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"/>
          </div>
        </div>
        <div class="space-y-4 pt-10">
          <div class="overflow-hidden" style="aspect-ratio: 4/3;">
            <img src="https://images.unsplash.com/photo-1631679706909-1844bbd07221?w=800&q=85&auto=format&fit=crop" alt="Elegant bedroom design" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"/>
          </div>
          <div class="overflow-hidden" style="aspect-ratio: 3/4;">
            <img src="https://images.unsplash.com/photo-1583847268964-b28dc8f51f92?w=800&q=85&auto=format&fit=crop" alt="Custom wardrobe design" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"/>
          </div>
        </div>
        <!-- Gold accent -->
        <div class="absolute -bottom-6 -right-6 w-32 h-32 hidden lg:block" style="background: #C9A84C; opacity: 0.15; z-index: -1;"></div>
      </div>

      <!-- Text -->
      <div>
        <div class="flex items-center gap-4 mb-6">
          <div class="w-10 h-px" style="background: #C9A84C;"></div>
          <span class="text-xs tracking-widest uppercase" style="font-family: 'Inter', sans-serif; color: #C9A84C; letter-spacing: 0.2em;">About Kala</span>
        </div>

        <h2 class="mb-6 leading-tight" style="font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(2rem, 4vw, 3.25rem); color: #0A1628;">
          Where Artistry Meets<br/><em>Thoughtful Design</em>
        </h2>

        <p class="mb-5 leading-relaxed" style="font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.9375rem; color: rgba(10,22,40,0.65);">
          Founded by Vivek Kumar Thodupunuri, Kala Interiors & Decor has been redefining interior spaces across Telangana. We believe your home should be a reflection of who you are — beautiful, functional, and uniquely yours.
        </p>
        <p class="mb-8 leading-relaxed" style="font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.9375rem; color: rgba(10,22,40,0.65);">
          From concept to completion, our team of skilled craftsmen and designers work closely with you to create interiors that stand the test of time. Every detail, every material, every finish is chosen with purpose and precision.
        </p>

        <div class="grid grid-cols-2 gap-6 mb-10">
          <div class="border-l-2 pl-4" style="border-color: #C9A84C;">
            <div class="text-sm font-medium mb-1" style="font-family: 'Inter', sans-serif; color: #0A1628;">Premium Materials</div>
            <div class="text-xs leading-relaxed" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.55); font-weight: 300;">Curated selection of top-grade materials for lasting beauty</div>
          </div>
          <div class="border-l-2 pl-4" style="border-color: #C9A84C;">
            <div class="text-sm font-medium mb-1" style="font-family: 'Inter', sans-serif; color: #0A1628;">On-Time Delivery</div>
            <div class="text-xs leading-relaxed" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.55); font-weight: 300;">Committed to completing your project on schedule</div>
          </div>
          <div class="border-l-2 pl-4" style="border-color: #C9A84C;">
            <div class="text-sm font-medium mb-1" style="font-family: 'Inter', sans-serif; color: #0A1628;">Custom 3D Designs</div>
            <div class="text-xs leading-relaxed" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.55); font-weight: 300;">Visualize your space before a single nail is driven</div>
          </div>
          <div class="border-l-2 pl-4" style="border-color: #C9A84C;">
            <div class="text-sm font-medium mb-1" style="font-family: 'Inter', sans-serif; color: #0A1628;">Pan-Telangana</div>
            <div class="text-xs leading-relaxed" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.55); font-weight: 300;">Serving clients across all districts of Telangana</div>
          </div>
        </div>

        <%= link_to about_path, class: "inline-flex items-center gap-3 text-xs tracking-widest uppercase border-b pb-0.5 transition-all hover:gap-5", style: "font-family: 'Inter', sans-serif; color: #C9A84C; border-color: #C9A84C;" do %>
          Discover Our Story
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES SECTION -->
<section class="py-24 lg:py-32" style="background: #0A1628;">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-4 mb-6">
        <div class="w-10 h-px" style="background: #C9A84C;"></div>
        <span class="text-xs tracking-widest uppercase" style="font-family: 'Inter', sans-serif; color: #C9A84C; letter-spacing: 0.2em;">What We Offer</span>
        <div class="w-10 h-px" style="background: #C9A84C;"></div>
      </div>
      <h2 class="mb-4 leading-tight" style="font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(2rem, 4vw, 3rem); color: #F8F7F4;">
        Our <em style="color: #C9A84C;">Services</em>
      </h2>
      <p class="max-w-xl mx-auto" style="font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.9375rem; color: rgba(248,247,244,0.5);">
        A complete suite of interior design solutions to transform every corner of your home.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Service Card 1 -->
      <div class="group relative overflow-hidden cursor-pointer" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(201,168,76,0.12);">
        <div class="overflow-hidden" style="height: 220px;">
          <img src="https://images.unsplash.com/photo-1583847268964-b28dc8f51f92?w=800&q=85&auto=format&fit=crop" alt="Plywood cupboards" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" style="opacity: 0.7;"/>
        </div>
        <div class="p-6">
          <div class="w-8 h-px mb-4" style="background: #C9A84C;"></div>
          <h3 class="mb-2 text-xl" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: #F8F7F4;">Plywood Cupboards</h3>
          <p class="text-xs leading-relaxed" style="font-family: 'Inter', sans-serif; font-weight: 300; color: rgba(248,247,244,0.5);">Durable, beautifully crafted plywood wardrobes and cabinets tailored to your space and style.</p>
        </div>
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(to top, rgba(201,168,76,0.1), transparent); pointer-events: none;"></div>
      </div>

      <!-- Service Card 2 -->
      <div class="group relative overflow-hidden cursor-pointer" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(201,168,76,0.12);">
        <div class="overflow-hidden" style="height: 220px;">
          <img src="https://images.unsplash.com/photo-1616137466211-f998e03edb2c?w=800&q=85&auto=format&fit=crop" alt="PVC cupboards" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" style="opacity: 0.7;"/>
        </div>
        <div class="p-6">
          <div class="w-8 h-px mb-4" style="background: #C9A84C;"></div>
          <h3 class="mb-2 text-xl" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: #F8F7F4;">PVC Cupboards</h3>
          <p class="text-xs leading-relaxed" style="font-family: 'Inter', sans-serif; font-weight: 300; color: rgba(248,247,244,0.5);">Moisture-resistant PVC cabinets ideal for kitchens, bathrooms, and high-humidity spaces.</p>
        </div>
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(to top, rgba(201,168,76,0.1), transparent); pointer-events: none;"></div>
      </div>

      <!-- Service Card 3 -->
      <div class="group relative overflow-hidden cursor-pointer" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(201,168,76,0.12);">
        <div class="overflow-hidden" style="height: 220px;">
          <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85&auto=format&fit=crop" alt="False ceiling design" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" style="opacity: 0.7;"/>
        </div>
        <div class="p-6">
          <div class="w-8 h-px mb-4" style="background: #C9A84C;"></div>
          <h3 class="mb-2 text-xl" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: #F8F7F4;">False Ceiling</h3>
          <p class="text-xs leading-relaxed" style="font-family: 'Inter', sans-serif; font-weight: 300; color: rgba(248,247,244,0.5);">Stunning gypsum and POP false ceilings with integrated lighting to elevate any room.</p>
        </div>
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(to top, rgba(201,168,76,0.1), transparent); pointer-events: none;"></div>
      </div>

      <!-- Service Card 4 -->
      <div class="group relative overflow-hidden cursor-pointer" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(201,168,76,0.12);">
        <div class="overflow-hidden" style="height: 220px;">
          <img src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=800&q=85&auto=format&fit=crop" alt="Wallpaper interior design" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" style="opacity: 0.7;"/>
        </div>
        <div class="p-6">
          <div class="w-8 h-px mb-4" style="background: #C9A84C;"></div>
          <h3 class="mb-2 text-xl" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: #F8F7F4;">Wallpapers</h3>
          <p class="text-xs leading-relaxed" style="font-family: 'Inter', sans-serif; font-weight: 300; color: rgba(248,247,244,0.5);">Curated wallpaper collections from subtle textures to bold patterns for every aesthetic.</p>
        </div>
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(to top, rgba(201,168,76,0.1), transparent); pointer-events: none;"></div>
      </div>

      <!-- Service Card 5 -->
      <div class="group relative overflow-hidden cursor-pointer" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(201,168,76,0.12);">
        <div class="overflow-hidden" style="height: 220px;">
          <img src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=800&q=85&auto=format&fit=crop" alt="Sofa and seating" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" style="opacity: 0.7;"/>
        </div>
        <div class="p-6">
          <div class="w-8 h-px mb-4" style="background: #C9A84C;"></div>
          <h3 class="mb-2 text-xl" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: #F8F7F4;">Sofas & Cushioning</h3>
          <p class="text-xs leading-relaxed" style="font-family: 'Inter', sans-serif; font-weight: 300; color: rgba(248,247,244,0.5);">Premium seating solutions with custom upholstery and cushioning to match your decor.</p>
        </div>
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(to top, rgba(201,168,76,0.1), transparent); pointer-events: none;"></div>
      </div>

      <!-- Service Card 6 - CTA card -->
      <div class="flex flex-col items-center justify-center p-8 text-center" style="background: #C9A84C; min-height: 350px;">
        <div class="text-5xl mb-4" style="font-family: 'Cormorant Garamond', serif; font-weight: 300; color: #0A1628;">13</div>
        <div class="text-xs tracking-widest uppercase mb-4" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.7); letter-spacing: 0.15em;">Premium Services</div>
        <p class="mb-6 text-sm leading-relaxed" style="font-family: 'Inter', sans-serif; font-weight: 300; color: rgba(10,22,40,0.7);">Plus Blinds, Curtains, Painting, Beds, PVC Ceiling, 3D Design & Pleated Mesh Doors</p>
        <%= link_to services_path, class: "inline-flex items-center gap-2 text-xs tracking-widest uppercase px-6 py-3 transition-all hover:gap-4", style: "font-family: 'Inter', sans-serif; background: #0A1628; color: #C9A84C;" do %>
