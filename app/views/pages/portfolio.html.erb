<% content_for :title, "Portfolio — Kala Interiors & Decor" %>

<!-- HERO -->
<section class="relative flex items-center justify-center overflow-hidden" style="background: #0A1628; min-height: 55vh;">
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?w=1920&q=90&auto=format&fit=crop"
      alt="Interior design portfolio"
      class="w-full h-full object-cover"
      style="opacity: 0.2;"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(10,22,40,0.6), rgba(10,22,40,0.92));"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 text-center py-32">
    <div class="flex items-center justify-center gap-4 mb-6">
      <div class="w-10 h-px" style="background: #C9A84C;"></div>
      <span class="text-xs tracking-widest uppercase" style="font-family: 'Inter', sans-serif; color: #C9A84C; letter-spacing: 0.2em;">Our Work</span>
      <div class="w-10 h-px" style="background: #C9A84C;"></div>
    </div>
    <h1 class="mb-4 leading-none" style="font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(2.5rem, 6vw, 5rem); color: #F8F7F4;">
      Our <em style="color: #C9A84C;">Portfolio</em>
    </h1>
    <p class="max-w-lg mx-auto" style="font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.9375rem; color: rgba(248,247,244,0.55);">
      A curated selection of our finest interior projects from across Telangana, spanning living rooms, bedrooms, kitchens, and more.
    </p>
  </div>
</section>

<!-- FILTER + GRID -->
<section class="py-20 lg:py-28" style="background: #F8F7F4;">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Filter Tabs -->
    <div class="flex flex-wrap gap-2 justify-center mb-16" id="filter-tabs">
      <% ["All", "Living Room", "Bedroom", "Kitchen", "Wardrobe", "Ceiling"].each_with_index do |cat, i| %>
        <button
          class="filter-btn px-5 py-2.5 text-xs tracking-widest uppercase transition-all duration-200"
          data-filter="<%= cat == 'All' ? 'all' : cat.downcase.gsub(' ', '-') %>"
          style="font-family: 'Inter', sans-serif; <%= i == 0 ? 'background: #0A1628; color: #C9A84C; border: 1px solid #0A1628;' : 'background: transparent; color: rgba(10,22,40,0.6); border: 1px solid rgba(10,22,40,0.2);' %>"
        >
          <%= cat %>
        </button>
      <% end %>
    </div>

    <!-- Project Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="portfolio-grid">

      <%
        projects = [
          { title: "Grand Living Villa", location: "Hyderabad", category: "Living Room", cat_slug: "living-room", img: "https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?w=800&q=85&auto=format&fit=crop", alt: "Luxury living room Hyderabad", tall: true },
          { title: "Master Suite Retreat", location: "Warangal", category: "Bedroom", cat_slug: "bedroom", img: "https://images.unsplash.com/photo-1631679706909-1844bbd07221?w=800&q=85&auto=format&fit=crop", alt: "Master bedroom suite design" },
          { title: "Modular Kitchen Pro", location: "Karimnagar", category: "Kitchen", cat_slug: "kitchen", img: "https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=85&auto=format&fit=crop", alt: "Modular kitchen interior" },
          { title: "Walk-in Wardrobe", location: "Nizamabad", category: "Wardrobe", cat_slug: "wardrobe", img: "https://images.unsplash.com/photo-1583847268964-b28dc8f51f92?w=800&q=85&auto=format&fit=crop", alt: "Custom walk-in wardrobe", tall: true },
          { title: "Coffered False Ceiling", location: "Khammam", category: "Ceiling", cat_slug: "ceiling", img: "https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85&auto=format&fit=crop", alt: "Coffered false ceiling design" },
          { title: "Contemporary Living", location: "Nalgonda", category: "Living Room", cat_slug: "living-room", img: "https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=800&q=85&auto=format&fit=crop", alt: "Contemporary living room design" },
          { title: "Plywood Bedroom Suite", location: "Siddipet", category: "Bedroom", cat_slug: "bedroom", img: "https://images.unsplash.com/photo-1616594039964-ae9021a400a0?w=800&q=85&auto=format&fit=crop", alt: "Bedroom furniture and wardrobe" },
          { title: "Open Kitchen Design", location: "Medak", category: "Kitchen", cat_slug: "kitchen", img: "https://images.unsplash.com/photo-1556909172-54557c7e4fb7?w=800&q=85&auto=format&fit=crop", alt: "Open plan kitchen design", tall: true },
          { title: "Cove Lit Ceiling", location: "Adilabad", category: "Ceiling", cat_slug: "ceiling", img: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=85&auto=format&fit=crop", alt: "Cove lighting false ceiling" },
          { title: "Boutique Living Room", location: "Mahabubnagar", category: "Living Room", cat_slug: "living-room", img: "https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=800&q=85&auto=format&fit=crop", alt: "Boutique living room sofa" },
          { title: "Built-in Wardrobe", location: "Sangareddy", category: "Wardrobe", cat_slug: "wardrobe", img: "https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=800&q=85&auto=format&fit=crop", alt: "Built-in bedroom wardrobe" },
          { title: "Kids Bedroom", location: "Yadadri", category: "Bedroom", cat_slug: "bedroom", img: "https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=800&q=85&auto=format&fit=crop", alt: "Colourful kids bedroom design" },
        ]
      %>

      <% projects.each do |p| %>
        <div
          class="portfolio-item group relative overflow-hidden cursor-pointer"
          data-category="<%= p[:cat_slug] %>"
          data-img="<%= p[:img] %>"
          data-title="<%= p[:title] %>"
          data-location="<%= p[:location] %>, Telangana"
          style="<%= p[:tall] ? 'height: 480px;' : 'height: 320px;' %>"
        >
          <img
            src="<%= p[:img] %>"
            alt="<%= p[:alt] %>"
            class="w-full h-full object-cover group-hover:scale-108 transition-transform duration-700"
            style="transition: transform 0.7s ease;"
            loading="lazy"
          />
          <!-- Overlay -->
          <div class="absolute inset-0 flex flex-col justify-end p-6" style="background: linear-gradient(to top, rgba(10,22,40,0.88) 0%, rgba(10,22,40,0.15) 55%, transparent 100%);">
            <div class="transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
              <div class="text-xs tracking-widest uppercase mb-1.5" style="font-family: 'Inter', sans-serif; color: #C9A84C; font-size: 9px; letter-spacing: 0.2em;"><%= p[:category] %></div>
              <h3 class="text-xl mb-1" style="font-family: 'Cormorant Garamond', serif; font-weight: 400; color: #F8F7F4;"><%= p[:title] %></h3>
              <div class="flex items-center gap-2 text-xs" style="font-family: 'Inter', sans-serif; color: rgba(248,247,244,0.55); font-weight: 300;">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <%= p[:location] %>, Telangana
              </div>
            </div>
          </div>
          <!-- Gold accent on hover -->
          <div class="absolute top-0 left-0 w-1 h-0 group-hover:h-full transition-all duration-500" style="background: #C9A84C;"></div>
        </div>
      <% end %>

    </div>

  </div>

  <!-- Lightbox -->
  <div id="lightbox" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(8,15,30,0.95); align-items:center; justify-content:center; padding:20px;">
    <button id="lightbox-close" style="position:absolute; top:24px; right:28px; color:white; background:none; border:none; cursor:pointer; font-size:32px; line-height:1; opacity:0.7;" aria-label="Close">&times;</button>
    <button id="lightbox-prev" style="position:absolute; left:20px; top:50%; transform:translateY(-50%); color:white; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); cursor:pointer; width:48px; height:48px; font-size:20px; display:flex; align-items:center; justify-content:center;">&#8592;</button>
    <button id="lightbox-next" style="position:absolute; right:20px; top:50%; transform:translateY(-50%); color:white; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); cursor:pointer; width:48px; height:48px; font-size:20px; display:flex; align-items:center; justify-content:center;">&#8594;</button>
    <div style="max-width:1000px; width:100%; text-align:center;">
      <img id="lightbox-img" src="" alt="" style="max-height:80vh; max-width:100%; object-fit:contain; display:block; margin:0 auto;">
      <div id="lightbox-caption" style="color:white; margin-top:16px; font-family:'Cormorant Garamond',serif; font-size:1.2rem;"></div>
      <div id="lightbox-location" style="color:rgba(201,168,76,0.8); font-size:12px; margin-top:4px; font-family:'Inter',sans-serif; letter-spacing:0.1em;"></div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20" style="background: #C9A84C;">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
    <h2 class="mb-4 leading-tight" style="font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(2rem, 4vw, 3rem); color: #0A1628;">
      Love What You See?
    </h2>
    <p class="mb-8 max-w-lg mx-auto" style="font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.9375rem; color: rgba(10,22,40,0.7);">
      Let's create something equally stunning for your home. Contact us today for a free design consultation.
    </p>
    <%= link_to contact_path, class: "inline-flex items-center gap-3 px-8 py-4 text-xs tracking-widest uppercase transition-all hover:gap-5", style: "font-family: 'Inter', sans-serif; background: #0A1628; color: #C9A84C; font-weight: 500;" do %>
      Start Your Project
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    <% end %>
  </div>
</section>

<script>
  function initPortfolioFilter() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const portfolioItems = document.querySelectorAll('.portfolio-item');

    if (!filterBtns.length) return;

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        filterBtns.forEach(b => {
          b.style.background = 'transparent';
          b.style.color = 'rgba(10,22,40,0.6)';
          b.style.border = '1px solid rgba(10,22,40,0.2)';
        });
        btn.style.background = '#0A1628';
        btn.style.color = '#C9A84C';
        btn.style.border = '1px solid #0A1628';

        portfolioItems.forEach(item => {
          if (filter === 'all' || item.dataset.category === filter) {
            item.style.display = 'block';
            item.style.opacity = '0';
            setTimeout(() => { item.style.opacity = '1'; item.style.transition = 'opacity 0.4s ease'; }, 10);
          } else {
            item.style.display = 'none';
          }
        });
      });
    });
  }

  // Runs on full page load and every Turbo navigation
  document.addEventListener('turbo:load', initPortfolioFilter);
  // Fallback for non-Turbo load
  document.addEventListener('DOMContentLoaded', initPortfolioFilter);

  function initLightbox() {
    const lightbox = document.getElementById('lightbox');
    const lbImg = document.getElementById('lightbox-img');
    const lbCaption = document.getElementById('lightbox-caption');
    const lbLocation = document.getElementById('lightbox-location');
    if (!lightbox) return;
    let currentItems = [];
    let currentIndex = 0;

    function openLightbox(items, index) {
      currentItems = items;
      currentIndex = index;
      showSlide(currentIndex);
      lightbox.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function showSlide(index) {
      const item = currentItems[index];
      lbImg.src = item.img;
      lbCaption.textContent = item.title;
      lbLocation.textContent = item.location;
    }

    function closeLightbox() {
      lightbox.style.display = 'none';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.portfolio-item').forEach((card, _, allCards) => {
      card.style.cursor = 'pointer';
      card.addEventListener('click', () => {
        const visibleCards = Array.from(document.querySelectorAll('.portfolio-item')).filter(c => c.style.display !== 'none');
        const idx = visibleCards.indexOf(card);
        const items = visibleCards.map(c => ({ img: c.dataset.img, title: c.dataset.title, location: c.dataset.location }));
        openLightbox(items, idx);
      });
    });

    document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
    document.getElementById('lightbox-prev')?.addEventListener('click', () => { currentIndex = (currentIndex - 1 + currentItems.length) % currentItems.length; showSlide(currentIndex); });
    document.getElementById('lightbox-next')?.addEventListener('click', () => { currentIndex = (currentIndex + 1) % currentItems.length; showSlide(currentIndex); });
    lightbox?.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); if (e.key === 'ArrowLeft' && lightbox.style.display === 'flex') { currentIndex = (currentIndex - 1 + currentItems.length) % currentItems.length; showSlide(currentIndex); } if (e.key === 'ArrowRight' && lightbox.style.display === 'flex') { currentIndex = (currentIndex + 1) % currentItems.length; showSlide(currentIndex); } });
  }

  document.addEventListener('turbo:load', initLightbox);
  document.addEventListener('DOMContentLoaded', initLightbox);
</script>
