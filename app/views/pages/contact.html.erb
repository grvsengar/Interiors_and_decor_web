<% content_for :title, "Contact Us — Kala Interiors & Decor" %>

<!-- HERO -->
<section class="relative flex items-center justify-center overflow-hidden" style="background: #0A1628; min-height: 50vh;">
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=1920&q=90&auto=format&fit=crop"
      alt="Contact Kala Interiors"
      class="w-full h-full object-cover"
      style="opacity: 0.15;"
    />
    <div class="absolute inset-0" style="background: rgba(10,22,40,0.88);"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 text-center py-28">
    <div class="flex items-center justify-center gap-4 mb-6">
      <div class="w-10 h-px" style="background: #C9A84C;"></div>
      <span class="text-xs tracking-widest uppercase" style="font-family: 'Inter', sans-serif; color: #C9A84C; letter-spacing: 0.2em;">Reach Out</span>
      <div class="w-10 h-px" style="background: #C9A84C;"></div>
    </div>
    <h1 class="mb-4 leading-none" style="font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(2.5rem, 6vw, 5rem); color: #F8F7F4;">
      Get In <em style="color: #C9A84C;">Touch</em>
    </h1>
    <p class="max-w-lg mx-auto" style="font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.9375rem; color: rgba(248,247,244,0.55);">
      Tell us about your space and vision. We'll get back to you within 24 hours with a free consultation.
    </p>
  </div>
</section>

<!-- CONTACT INFO CARDS -->
<section style="background: #0A1628;">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 pb-0">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 -mb-12 relative z-10">

      <div class="flex items-start gap-5 p-8 lg:p-10" style="background: #C9A84C;">
        <div class="w-12 h-12 flex items-center justify-center flex-shrink-0" style="background: rgba(10,22,40,0.15);">
          <svg class="w-5 h-5" fill="none" stroke="#0A1628" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </div>
        <div>
          <div class="text-xs tracking-widest uppercase mb-2" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.6); font-size: 9px; letter-spacing: 0.2em;">Call Us</div>
          <a href="tel:+918686475754" class="block text-lg hover:opacity-80 transition-opacity" style="font-family: 'Cormorant Garamond', serif; font-weight: 500; color: #0A1628;">+91 86864 75754</a>
          <div class="text-xs mt-1" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.6); font-weight: 300;">Mon–Sat, 9am–7pm</div>
        </div>
      </div>

      <div class="flex items-start gap-5 p-8 lg:p-10" style="background: #0B1C34; border-top: 3px solid #C9A84C;">
        <div class="w-12 h-12 flex items-center justify-center flex-shrink-0" style="background: rgba(201,168,76,0.1);">
          <svg class="w-5 h-5" fill="none" stroke="#C9A84C" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <div>
          <div class="text-xs tracking-widest uppercase mb-2" style="font-family: 'Inter', sans-serif; color: #C9A84C; font-size: 9px; letter-spacing: 0.2em;">Email Us</div>
          <a href="mailto:kalainteriorsanddecor@gmail.com" class="block text-sm hover:text-amber-300 transition-colors break-all" style="font-family: 'Inter', sans-serif; color: #F8F7F4; font-weight: 300;">kalainteriorsanddecor@gmail.com</a>
          <div class="text-xs mt-1" style="font-family: 'Inter', sans-serif; color: rgba(248,247,244,0.4); font-weight: 300;">We reply within 24 hours</div>
        </div>
      </div>

      <div class="flex items-start gap-5 p-8 lg:p-10" style="background: #0B1C34; border-top: 3px solid #C9A84C;">
        <div class="w-12 h-12 flex items-center justify-center flex-shrink-0" style="background: rgba(201,168,76,0.1);">
          <svg class="w-5 h-5" fill="#C9A84C" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </div>
        <div>
          <div class="text-xs tracking-widest uppercase mb-2" style="font-family: 'Inter', sans-serif; color: #C9A84C; font-size: 9px; letter-spacing: 0.2em;">Instagram</div>
          <a href="https://instagram.com/kala_interiorsanddecor" target="_blank" class="block text-sm hover:text-amber-300 transition-colors" style="font-family: 'Inter', sans-serif; color: #F8F7F4; font-weight: 300;">@kala_interiorsanddecor</a>
          <div class="text-xs mt-1" style="font-family: 'Inter', sans-serif; color: rgba(248,247,244,0.4); font-weight: 300;">View our latest work</div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- FORM + MAP -->
<section class="pt-24 pb-20 lg:pt-32 lg:pb-28" style="background: #F8F7F4;">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

      <!-- Form: 3 cols -->
      <div class="lg:col-span-3">
        <div class="mb-10">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-px" style="background: #C9A84C;"></div>
            <span class="text-xs tracking-widest uppercase" style="font-family: 'Inter', sans-serif; color: #C9A84C; letter-spacing: 0.2em;">Free Consultation</span>
          </div>
          <h2 class="leading-tight" style="font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(1.75rem, 3.5vw, 2.5rem); color: #0A1628;">
            Tell Us About<br/><em>Your Project</em>
          </h2>
        </div>

        <%= form_with url: contact_path, method: :post, local: true, class: "space-y-5", id: "contact-form", novalidate: true do |f| %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-xs tracking-widest uppercase mb-2" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.55); letter-spacing: 0.15em;">Full Name *</label>
              <%= f.text_field :name, placeholder: "Your full name",
                class: "kala-field w-full px-4 py-3.5 text-sm outline-none transition-all",
                style: "font-family: 'Inter', sans-serif; background: white; border: 1px solid rgba(10,22,40,0.15); color: #0A1628; font-weight: 300;",
                required: true,
                data: { error: "Please enter your full name" } %>
              <span class="kala-error hidden mt-1 text-xs" style="color: #c0392b; font-family: 'Inter', sans-serif;"></span>
            </div>
            <div>
              <label class="block text-xs tracking-widest uppercase mb-2" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.55); letter-spacing: 0.15em;">Phone Number *</label>
              <%= f.telephone_field :phone, placeholder: "+91 XXXXX XXXXX",
                class: "kala-field w-full px-4 py-3.5 text-sm outline-none transition-all",
                style: "font-family: 'Inter', sans-serif; background: white; border: 1px solid rgba(10,22,40,0.15); color: #0A1628; font-weight: 300;",
                required: true,
                data: { error: "Please enter your phone number" } %>
              <span class="kala-error hidden mt-1 text-xs" style="color: #c0392b; font-family: 'Inter', sans-serif;"></span>
            </div>
          </div>

          <div>
            <label class="block text-xs tracking-widest uppercase mb-2" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.55); letter-spacing: 0.15em;">Email Address</label>
            <%= f.email_field :email, placeholder: "your@email.com",
              class: "kala-field w-full px-4 py-3.5 text-sm outline-none transition-all",
              style: "font-family: 'Inter', sans-serif; background: white; border: 1px solid rgba(10,22,40,0.15); color: #0A1628; font-weight: 300;",
              data: { error: "Please enter a valid email address" } %>
            <span class="kala-error hidden mt-1 text-xs" style="color: #c0392b; font-family: 'Inter', sans-serif;"></span>
          </div>

          <div>
            <label class="block text-xs tracking-widest uppercase mb-2" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.55); letter-spacing: 0.15em;">Service Required *</label>
            <%= f.select :service,
              options_for_select([
                ["Select a service...", ""],
                ["Plywood Cupboards", "plywood_cupboards"],
                ["PVC Cupboards", "pvc_cupboards"],
                ["Blinds", "blinds"],
                ["Wallpapers", "wallpapers"],
                ["Painting", "painting"],
                ["Pleated Mesh Doors (Sliding)", "pleated_mesh_doors"],
                ["3D Design", "3d_design"],
                ["Beds & Bedroom Furniture", "beds"],
                ["False Ceiling", "false_ceiling"],
                ["PVC Ceiling", "pvc_ceiling"],
                ["Curtains", "curtains"],
                ["Sofas", "sofas"],
                ["Cushioning", "cushioning"],
                ["Full Home Interior", "full_home"],
                ["Multiple Services", "multiple"]
              ]),
              {},
              class: "kala-field w-full px-4 py-3.5 text-sm outline-none appearance-none",
              style: "font-family: 'Inter', sans-serif; background: white; border: 1px solid rgba(10,22,40,0.15); color: #0A1628; font-weight: 300; cursor: pointer;",
              required: true,
              data: { error: "Please select a service" } %>
            <span class="kala-error hidden mt-1 text-xs" style="color: #c0392b; font-family: 'Inter', sans-serif;"></span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-xs tracking-widest uppercase mb-2" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.55); letter-spacing: 0.15em;">City / District</label>
              <%= f.text_field :city, placeholder: "e.g. Hyderabad",
                class: "kala-field w-full px-4 py-3.5 text-sm outline-none",
                style: "font-family: 'Inter', sans-serif; background: white; border: 1px solid rgba(10,22,40,0.15); color: #0A1628; font-weight: 300;" %>
            </div>
            <div>
              <label class="block text-xs tracking-widest uppercase mb-2" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.55); letter-spacing: 0.15em;">Budget Range</label>
              <%= f.select :budget,
                options_for_select([
                  ["Select budget...", ""],
                  ["Under ₹1 Lakh", "under_1l"],
                  ["₹1 – ₹3 Lakhs", "1_3l"],
                  ["₹3 – ₹7 Lakhs", "3_7l"],
                  ["₹7 – ₹15 Lakhs", "7_15l"],
                  ["₹15 Lakhs+", "15l_plus"]
                ]),
                {},
                class: "kala-field w-full px-4 py-3.5 text-sm outline-none appearance-none",
                style: "font-family: 'Inter', sans-serif; background: white; border: 1px solid rgba(10,22,40,0.15); color: #0A1628; font-weight: 300; cursor: pointer;" %>
            </div>
          </div>

          <div>
            <label class="block text-xs tracking-widest uppercase mb-2" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.55); letter-spacing: 0.15em;">Your Message *</label>
            <%= f.text_area :message,
              rows: 5,
              placeholder: "Describe your project, space dimensions, preferred style, or any specific requirements...",
              class: "kala-field w-full px-4 py-3.5 text-sm outline-none resize-none",
              style: "font-family: 'Inter', sans-serif; background: white; border: 1px solid rgba(10,22,40,0.15); color: #0A1628; font-weight: 300;",
              required: true,
              data: { error: "Please describe your project" } %>
            <span class="kala-error hidden mt-1 text-xs" style="color: #c0392b; font-family: 'Inter', sans-serif;"></span>
          </div>

          <button type="submit" class="w-full py-4 text-xs tracking-widest uppercase transition-all hover:opacity-90 flex items-center justify-center gap-3" style="font-family: 'Inter', sans-serif; background: #0A1628; color: #C9A84C; font-weight: 500; letter-spacing: 0.15em;">
            Send Message
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </button>

          <p class="text-center text-xs" style="font-family: 'Inter', sans-serif; color: rgba(10,22,40,0.4); font-weight: 300;">
            We'll respond within 24 hours. Your information is kept confidential.
          </p>
        <% end %>

        <script>
          (function() {
            var form = document.getElementById('contact-form');
            if (!form) return;

            function showError(field, msg) {
              field.style.borderColor = '#c0392b';
              var err = field.parentElement.querySelector('.kala-error');
              if (err) { err.textContent = msg; err.classList.remove('hidden'); }
            }

            function clearError(field) {
              field.style.borderColor = 'rgba(10,22,40,0.15)';
              var err = field.parentElement.querySelector('.kala-error');
              if (err) { err.textContent = ''; err.classList.add('hidden'); }
            }

            // Clear error on input/change
            form.querySelectorAll('.kala-field').forEach(function(field) {
              field.addEventListener('input', function() { clearError(field); });
              field.addEventListener('change', function() { clearError(field); });
            });

            function validateForm(e) {
              var valid = true;

              form.querySelectorAll('.kala-field[required]').forEach(function(field) {
                clearError(field);
                var empty = field.value.trim() === '' || (field.tagName === 'SELECT' && field.value === '');
                if (empty) {
                  showError(field, field.dataset.error || 'This field is required');
                  if (valid) { field.focus(); field.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
                  valid = false;
                }
              });

              // Email format check if filled
              var emailField = form.querySelector('input[type="email"]');
              if (emailField && emailField.value.trim() !== '') {
                var emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailField.value.trim());
                if (!emailOk) {
                  showError(emailField, emailField.dataset.error || 'Please enter a valid email address');
                  if (valid) { emailField.focus(); emailField.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
                  valid = false;
                }
              }

              if (!valid) e.preventDefault();
            }

            // Handle both plain submit and Turbo's submit interception
            form.addEventListener('submit', validateForm);
            form.addEventListener('turbo:submit-start', validateForm);
          })();
        </script>
      </div>

      <!-- Side info: 2 cols -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Map Placeholder -->
        <div class="overflow-hidden" style="height: 280px; background: #0A1628; position: relative;">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d243647.5!2d78.4867!3d17.3850!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bcb99daeaebd2c7%3A0xae93b78392bafbc2!2sHyderabad%2C%20Telangana!5e0!3m2!1sen!2sin!4v1700000000000!5m2!1sen!2sin"
            width="100%"
            height="280"
            style="border:0; filter: invert(90%) hue-rotate(180deg) saturate(0.7);"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Kala Interiors location - Telangana"
          ></iframe>
          <div class="absolute bottom-0 left-0 right-0 px-4 py-3" style="background: rgba(10,22,40,0.85);">
            <div class="text-xs" style="font-family: 'Inter', sans-serif; color: #C9A84C; font-weight: 300;">Serving all of Telangana, India</div>
          </div>
        </div>

        <!-- WhatsApp CTA -->
        <a href="https://wa.me/918686475754?text=Hi%20Kala%20Interiors%2C%20I%27m%20interested%20in%20your%20interior%20design%20services.%20Please%20get%20in%20touch." target="_blank" class="flex items-center gap-5 p-6 group transition-all hover:opacity-90" style="background: #25D366; text-decoration: none;">
          <div class="w-14 h-14 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.2);">
            <svg class="w-7 h-7" fill="white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <div class="text-white font-medium mb-0.5" style="font-family: 'Inter', sans-serif; font-size: 0.9375rem;">Chat on WhatsApp</div>
            <div class="text-white/80 text-xs" style="font-family: 'Inter', sans-serif; font-weight: 300;">Quick replies — usually within minutes</div>
          </div>
          <svg class="w-5 h-5 text-white ml-auto opacity-60 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>

        <!-- Working hours -->
        <div class="p-6" style="background: white; border-top: 3px solid #C9A84C;">
          <div class="text-xs tracking-widest uppercase mb-5" style="font-family: 'Inter', sans-serif; color: #C9A84C; letter-spacing: 0.2em;">Working Hours</div>
          <div class="space-y-3">
            <% [["Monday – Friday", "9:00 AM – 7:00 PM"], ["Saturday", "9:00 AM – 5:00 PM"], ["Sunday", "By Appointment Only"]].each do |day, hrs| %>
              <div class="flex items-center justify-between text-sm" style="font-family: 'Inter', sans-serif;">
                <span style="color: rgba(10,22,40,0.65); font-weight: 300;"><%= day %></span>
                <span style="color: #0A1628; font-weight: 400;"><%= hrs %></span>
              </div>
              <div class="h-px" style="background: rgba(10,22,40,0.06);"></div>
            <% end %>
          </div>
        </div>

        <!-- Service area -->
        <div class="p-6" style="background: #0A1628;">
          <div class="text-xs tracking-widest uppercase mb-4" style="font-family: 'Inter', sans-serif; color: #C9A84C; letter-spacing: 0.2em;">Service Area</div>
          <p class="text-xs leading-relaxed mb-4" style="font-family: 'Inter', sans-serif; font-weight: 300; color: rgba(248,247,244,0.55);">We serve all districts of Telangana including:</p>
          <div class="flex flex-wrap gap-2">
            <% ["Hyderabad", "Warangal", "Karimnagar", "Nizamabad", "Khammam", "Nalgonda", "Medak", "Mahbubnagar", "Adilabad", "Sangareddy", "Siddipet", "Yadadri"].each do |city| %>
              <span class="px-3 py-1 text-xs" style="font-family: 'Inter', sans-serif; color: rgba(248,247,244,0.6); background: rgba(255,255,255,0.06); font-weight: 300;"><%= city %></span>
            <% end %>
            <span class="px-3 py-1 text-xs" style="font-family: 'Inter', sans-serif; color: #C9A84C; background: rgba(201,168,76,0.1); font-weight: 300;">+ All Districts</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
